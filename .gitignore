###############################################################################
# .NET GitIgnore Template
# Author: cuthanhcam (enhanced & standardized)
# Description: Clean, professional .gitignore for .NET, ASP.NET Core, Blazor,
#              and modern frontend projects
###############################################################################

# ---------------------------------------------------------------------------
# IDE & Editor Files
# ---------------------------------------------------------------------------

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
ipch/
*.aps
*.ncb
*.opensdf
*.sdf
*.cachefile
*.psess
*.vsp
*.vspx

# Visual Studio Code
.vscode/

# JetBrains Rider / IntelliJ
.idea/
*.iml

# ReSharper
_ReSharper*/
*.DotSettings.user

# ---------------------------------------------------------------------------
# Build Outputs & Compiled Files
# ---------------------------------------------------------------------------

# .NET build output
bin/
obj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
artifacts/

# Compiler artifacts
*.ilk
*.obj
*.pch
*.pdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*.vspscc
*.vssscc
*.builds
*.pidb
*.svclog
*.scc

# ---------------------------------------------------------------------------
# NuGet & Package Management
# ---------------------------------------------------------------------------

packages/
!packages/repositories.config
*.nupkg
.nuget/

# ---------------------------------------------------------------------------
# Publish & Deployment Outputs
# ---------------------------------------------------------------------------

publish/
*.Publish.xml
*.pubxml
*.azurePubxml

# ---------------------------------------------------------------------------
# Test Results & Coverage
# ---------------------------------------------------------------------------

[Tt]est[Rr]esults/
[Bb]uild[Ll]og.*
coverage/
*.coverage
*.coveragexml

# ---------------------------------------------------------------------------
# Frontend / Node.js
# ---------------------------------------------------------------------------

node_modules/
dist/
build/
.vite/
.eslintcache
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ---------------------------------------------------------------------------
# Database Files & Local Storage
# ---------------------------------------------------------------------------

migrations/
*.db
*.sqlite
*.mdf
*.ldf

# ---------------------------------------------------------------------------
# Configuration & Secrets (DO NOT COMMIT)
# ---------------------------------------------------------------------------

.env
.env.*
*.pem
*.cert
*.key

# Ignore all appsettings files (base + environment-specific) to avoid leaking secrets
appsettings*.json

# ---------------------------------------------------------------------------
# Docker & DevOps
# ---------------------------------------------------------------------------

docker-compose.override.yml
docker-compose.override.yaml
.env.docker
.docker/
Dockerfile.local
.dockerignore

# Terraform
.terraform/
*.tfstate
*.tfstate.*

# ---------------------------------------------------------------------------
# System & OS Generated Files
# ---------------------------------------------------------------------------

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------

*.log
logs/
Logs/
!*.important.log

# ---------------------------------------------------------------------------
# Backup & Upgrade Files
# ---------------------------------------------------------------------------

_UpgradeReport_Files/
Backup/
UpgradeLog.XML
UpgradeLog.htm

# ---------------------------------------------------------------------------
# Python (if used for scripts or tooling)
# ---------------------------------------------------------------------------

__pycache__/
*.pyc
*.pyo

# ---------------------------------------------------------------------------
# Blazor / WebAssembly
# ---------------------------------------------------------------------------

wwwroot/service-worker.js
wwwroot/service-worker-assets.js

# ---------------------------------------------------------------------------
# Miscellaneous
# ---------------------------------------------------------------------------

*.meta
*.cache