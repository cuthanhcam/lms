root = true

# Apply to all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# C# files
[*.cs]
indent_style = space
indent_size = 4

# JSON
[*.json]
indent_size = 2

# YAML
[*.yml]
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false

# XML (csproj, props, targets)
[*.{csproj,props,targets,xml}]
indent_size = 2