###############################################################################
# LMS.Portal Frontend GitIgnore Template
# Derived from repository root standards and tailored for React/TypeScript monorepo
###############################################################################

# ---------------------------------------------------------------------------
# IDE & Editor Files
# ---------------------------------------------------------------------------

# Visual Studio Code
.vscode/

# JetBrains Rider / IntelliJ
.idea/
*.iml
.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/usage.statistics.xml

# ---------------------------------------------------------------------------
# Frontend Dependencies & Package Manager
# ---------------------------------------------------------------------------

node_modules/
.pnpm-store/
.pnp
.pnp.js

# ---------------------------------------------------------------------------
# Build Outputs & Runtime Artifacts
# ---------------------------------------------------------------------------

dist/
build/
**/dist/
**/build/
.vite/
*.tsbuildinfo

# Turbo cache
.turbo/

# ---------------------------------------------------------------------------
# Testing & Coverage
# ---------------------------------------------------------------------------

coverage/
[Tt]est[Rr]esults/

# ---------------------------------------------------------------------------
# Environment & Secrets
# ---------------------------------------------------------------------------

.env
.env.*
!.env.example
*.pem
*.cert
*.key

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------------------------------------------------------------
# Deployment / Hosting
# ---------------------------------------------------------------------------

.vercel/

# ---------------------------------------------------------------------------
# System Files
# ---------------------------------------------------------------------------

Thumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store

# ---------------------------------------------------------------------------
# Miscellaneous
# ---------------------------------------------------------------------------

*.cache
